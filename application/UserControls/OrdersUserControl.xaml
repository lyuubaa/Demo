<UserControl x:Class="ShoesShop.UserControls.OrdersUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShoesShop.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" MinWidth="500" Background="White">
    <Grid>
        <Border BorderBrush="#67BA80" BorderThickness="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="30,10,0,10">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20">
                        <Run Text="Номер заказа: "/>
                        <Run Text="{Binding OrderId}"/>
                    </TextBlock>

                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Run Text="Статус заказа: "/>
                        <Run Text="{Binding OrderStatus}"/>
                    </TextBlock>

                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Run Text="Адрес пункта выдачи: "/>
                        <Run x:Name="adr" Text="dfvb"/>
                    </TextBlock>
                    <WrapPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
                             <Run Text="Дата заказа: "/>
                             <!--<Run x:Name="orderDate_txt" Text="{Binding OrderDate}"/>-->
                        </TextBlock>
                        <TextBlock  x:Name="orderDate_txt"/>
                    </WrapPanel>
                    
                </StackPanel>


                <StackPanel x:Name="percent" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Дата доставки: " VerticalAlignment="Center" Padding="5"/>
                    <TextBlock x:Name="deliveryDate_txt" HorizontalAlignment="Center"  Padding="0 5">
                         <Run Text="{Binding DeliveryDate}"/>
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>
