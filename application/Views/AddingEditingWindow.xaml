<Window x:Class="ShoesShop.Views.AddingEditingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop.Views"
        mc:Ignorable="d"
        Title="Редактирование/Добавление товара"  
        MaxHeight="616" MaxWidth="528" MinHeight="616" MinWidth="528" 
        Icon="/Resources/Icon.ico" WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
              HorizontalScrollBarVisibility="Disabled">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" 
                   x:Name="window_name_txt"
                   Text="РЕДАКТИРОВАНИЕ" 
                   FontSize="20" 
                   HorizontalAlignment="Center" 
                   Margin="0,10,0,20"/>

        <Border Grid.Row="1" Grid.Column="1" 
                BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Margin="10">
            <Grid>
                <Image x:Name="imageItem" 
                       Source="/Resources/picture.png" 
                       Stretch="Uniform" 
                       Height="180" Width="250"
                       MouseDown="Image_MouseDown" 
                       Cursor="Hand"/>
                <TextBlock Text="Нажмите для выбора фото" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Bottom" 
                           Margin="0,0,0,5" 
                           Foreground="Red" 
                           FontSize="12"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

            <TextBlock Grid.Row="2" Grid.Column="1" 
                   Margin="10,5">
                <Run Text="Наименование товара"/>
                <Run x:Name="artic" Text=""/>
            </TextBlock>
        <TextBox x:Name="tovarName_txt" 
                 Grid.Row="3" Grid.Column="1" 
                 Margin="10,0,10,10" 
                 Padding="5"/>

        <TextBlock Grid.Row="4" Grid.Column="1" 
                   Text="Категория товара:" 
                   Margin="10,5"/>
        <ComboBox x:Name="category_cb" 
                  Grid.Row="5" Grid.Column="1" 
                  Margin="10,0,10,10" 
                  Padding="5"
                  DisplayMemberPath="CategoryName"/>

        <TextBlock Grid.Row="6" Grid.Column="1" 
                   Text="Описание товара:" 
                   Margin="10,5"/>
        <TextBox x:Name="description_txt" 
                 Grid.Row="7" Grid.Column="1" 
                 Margin="10,0,10,10" 
                 Padding="5" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True" 
                 MinHeight="60"/>

        <TextBlock Grid.Row="8" Grid.Column="1" 
                   Text="Производитель:" 
                   Margin="10,5"/>
        <ComboBox x:Name="manufacturer_cb" 
                  Grid.Row="9" Grid.Column="1" 
                  Margin="10,0,10,10" 
                  Padding="5"
                  DisplayMemberPath="ManufacturerName"/>

        <TextBlock Grid.Row="10" Grid.Column="1" 
                   Text="Поставщик:" 
                   Margin="10,5"/>
        <ComboBox x:Name="supplier_cb" 
                  Grid.Row="11" Grid.Column="1" 
                  Margin="10,0,10,10" 
                  Padding="5"
                  DisplayMemberPath="SupplierName"/>

        <Grid Grid.Row="12" Grid.Column="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="price_txt" 
                     Grid.Column="0" 
                     Padding="5"/>
            <TextBlock Grid.Column="1" 
                       Text="руб." 
                       VerticalAlignment="Center" 
                       Margin="5,0"/>
            <TextBox x:Name="unit_txt" Text="шт." IsEnabled="False"
                     Grid.Column="2" 
                     Padding="5"/>
        </Grid>

        <TextBlock Grid.Row="13" Grid.Column="1" 
                   Text="Количество на складе:" 
                   Margin="10,5"/>
        <TextBox x:Name="quantity_txt" 
                 Grid.Row="14" Grid.Column="1" 
                 Margin="10,0,10,10" 
                 Padding="5"/>

        <TextBlock Grid.Row="15" Grid.Column="1" 
                   Text="Действующая скидка (%):" 
                   Margin="10,5"/>
        <TextBox x:Name="discount_txt" 
                 Grid.Row="16" Grid.Column="1" 
                 Margin="10,0,10,10" 
                 Padding="5"/>

        <Button x:Name="save_btn" 
                Grid.Row="17" Grid.Column="1" 
                Content="СОХРАНИТЬ" 
                Margin="10,10,10,20" 
                Padding="10" 
                FontSize="16" 
                Background="Chartreuse" 
                Click="save_btn_Click"/>
    </Grid>
    </ScrollViewer>

</Window>