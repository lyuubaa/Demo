<Window x:Class="ShoesShop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Окно входа"  MinHeight="516" MinWidth="728" Icon="/Resources/Icon.ico" WindowStartupLocation="CenterScreen" >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="АВТОРИЗАЦИЯ" Grid.Row="1" Grid.Column="1" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="26"/>

        <TextBlock Text="логин" Grid.Row="2" Grid.Column="1" 
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                   FontSize="22"/>

        <TextBlock Text="пароль" Grid.Row="4" Grid.Column="1" 
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                   FontSize="22"/>

        <TextBox x:Name="login_txt" Grid.Row="3" Grid.Column="1" Padding="5 0" VerticalContentAlignment="Center" FontSize="20" FontFamily="Times New Roman"/>
        <PasswordBox x:Name="password_txt" Grid.Row="5" Padding="5 0" VerticalContentAlignment="Center" FontSize="20" Grid.Column="1"/>

        <Button x:Name="login_bt" Content="ВОЙТИ" Grid.Row="6" Grid.Column="1" 
                FontSize="26" Margin="10,10,10,0" 
                Background="Chartreuse" BorderBrush="MediumSpringGreen" 
                Click="login_bt_Click"/>

        <Button x:Name="login_as_guest_bt" Content="ВОЙТИ КАК ГОСТЬ" Grid.Row="7" Grid.Column="1" 
                FontSize="26" Margin="10,10,10,0" 
                BorderBrush="MediumSpringGreen" Background="{x:Null}" 
                Click="login_as_guest_bt_Click"/>
    </Grid>
</Window>