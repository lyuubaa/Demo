<Window x:Class="ShoesShop.Views.OrderAddingEditingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop.Views"
        mc:Ignorable="d"
        Title="Редактирование/Добавление заказа"  
        MaxHeight="530" MaxWidth="528" MinHeight="530" MinWidth="528" 
        Icon="/Resources/Icon.ico" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" 
               x:Name="window_name_txt"
               Text="РЕДАКТИРОВАНИЕ" 
               FontSize="20" 
               HorizontalAlignment="Center" 
               Margin="0,10,0,20"/>

        <TextBlock x:Name="orderNumber_tb" Grid.Row="1" Grid.Column="1" 
               Margin="10,5">
                <Run Text="Номер заказа"/>
        </TextBlock>
        <TextBox x:Name="orderNumber_txt" 
                 Grid.Row="2" Grid.Column="1" 
                 Margin="10,0,10,10" 
                 Padding="5"/>

        <TextBlock Grid.Row="3" Grid.Column="1" 
                   Text="Статус заказа:" 
                   Margin="10,5"/>
        <ComboBox x:Name="status_cb" 
                  Grid.Row="4" Grid.Column="1" 
                  Margin="10,0,10,10" SelectedIndex="0"
                  Padding="5">
            <ComboBoxItem>Новый</ComboBoxItem>
            <ComboBoxItem>Завершен</ComboBoxItem>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="1" 
               Text="Адрес пункта выдачи:" 
               Margin="10,5"/>
        <ComboBox x:Name="pickup_points_cb" 
                      Grid.Row="6" Grid.Column="1" 
                      Margin="10,0,10,10" 
                      Padding="5"/>

        <TextBlock Grid.Row="7" Grid.Column="1" 
                       Text="Дата заказа:" 
                       Margin="10,5"/>
        <DatePicker x:Name="orderDate_dp" 
                        Grid.Row="8" Grid.Column="1" 
                        Margin="10,0,10,10" 
                        Padding="5"/>


        <TextBlock Grid.Row="9" Grid.Column="1" 
                       Text="Дата выдачи:" 
                       Margin="10,5"/>
        <DatePicker x:Name="issueDate_dp" 
                        Grid.Row="10" Grid.Column="1" 
                        Margin="10,0,10,10" 
                        Padding="5"/>

        <Button x:Name="save_btn" 
                    Grid.Row="11" Grid.Column="1" 
                    Content="СОХРАНИТЬ" 
                    Margin="10,10,10,20" 
                    Padding="10" 
                    FontSize="16" 
                    Background="Chartreuse" Click="save_btn_Click" />
    </Grid>
</Window>
